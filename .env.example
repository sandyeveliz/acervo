# Acervo .env — only for standalone mode (acervo serve / acervo mcp)
# When using Acervo as an SDK (import), the caller passes its own LLM client
# and these variables are NOT read. See docs/configuration.md for details.

# Light model — entity/fact extraction and background tasks
ACERVO_LIGHT_MODEL_URL=http://localhost:1234/v1
ACERVO_LIGHT_MODEL=qwen2.5-3b-instruct
ACERVO_LIGHT_API_KEY=lm-studio

# Main model — reasoning and context (reserved for future use)
ACERVO_MAIN_MODEL_URL=http://localhost:1234/v1
ACERVO_MAIN_MODEL=unsloth/qwen3.5-9b
ACERVO_MAIN_API_KEY=lm-studio

# Storage
ACERVO_OWNER=default
ACERVO_DATA_DIR=./data
ACERVO_LOG_LEVEL=INFO
